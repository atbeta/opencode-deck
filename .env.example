# OpenDeck web server
OPENDECK_HOST=127.0.0.1
OPENDECK_PORT=55413
OPENDECK_DATABASE=.opendeck/opendeck.sqlite3

# OpenCode server (must already be running)
OPENCODE_SERVER_URL=http://127.0.0.1:14096
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=change-me

# Optional: restrict Dispatch / Harness workspaces (colon-separated on macOS/Linux)
# OPENDECK_ALLOWED_ROOTS=/Users/you/Projects:/other/path
# OPENDECK_STRICT_ROOTS=true
