# OpenDeck web server
# OpenDeck reads this file automatically — no `set -a` / `source` dance needed
# on macOS, Linux, or Windows.
OPENDECK_HOST=127.0.0.1
OPENDECK_PORT=55413
OPENDECK_DATABASE=.opendeck/opendeck.sqlite3

# OpenCode server (must already be running)
OPENCODE_SERVER_URL=http://127.0.0.1:14096
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=change-me

# Optional: restrict Dispatch / Harness workspaces.
#   POSIX (macOS/Linux): use ":" as separator
#   Windows: use ";" as separator (or ":" if you only have one entry)
# OPENDECK_ALLOWED_ROOTS=/Users/you/Projects:/other/path
# OPENDECK_STRICT_ROOTS=true

# Optional: HTTP Basic Auth for the dashboard (leave blank to disable).
# Useful when exposing OpenDeck to a LAN / VPN.
# OPENDECK_BASIC_AUTH_USER=admin
# OPENDECK_BASIC_AUTH_PASS=change-me

# Optional: Harness policy. ``OPENDECK_AUTO_DECIDE`` lets the harness send
# a default-answer prompt when the agent stops to ask which option to pick.
# ``OPENDECK_AUTO_DECIDE_MAX`` caps how many auto-decisions per session.
# OPENDECK_AUTO_DECIDE=true
# OPENDECK_AUTO_DECIDE_MAX=3
